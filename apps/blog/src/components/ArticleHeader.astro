---
import LayoutContainer from "./LayoutContainer.astro";
import { formatPublishedDate } from "../lib/date";
import type { PostEntry } from "../lib/posts";

interface Props {
  post: PostEntry;
  titleId: string;
}

const { post, titleId } = Astro.props;
---

<header class="article-hero">
  <LayoutContainer>
    <div class="article-hero__content">
      <p class="article-hero__meta">
        <span class="article-hero__category">{post.data.category}</span>
        <time datetime={post.data.publishedAt}>
          {formatPublishedDate(post.data.publishedAt)}
        </time>
      </p>

      <h1 id={titleId} class="article-hero__title">{post.data.title}</h1>
      <p class="article-hero__summary">{post.data.description}</p>

      {post.data.question && (
        <aside class="article-question" aria-labelledby="article-question-title">
          <h2 id="article-question-title">Question</h2>
          <p>{post.data.question}</p>
        </aside>
      )}
    </div>
  </LayoutContainer>
</header>

<style>
  .article-hero {
    margin-bottom: 48px;
  }

  .article-hero__content {
    border-bottom: 3px solid var(--color-primary);
    padding-bottom: 48px;
  }

  .article-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin: 0 0 24px;
    color: var(--color-secondary);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .article-hero__category {
    border-radius: 999px;
    padding: 6px 12px;
    background: #e8eeff;
    color: var(--color-tertiary);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .article-hero__title {
    margin: 0;
    color: var(--color-primary);
    font-size: clamp(2rem, 8vw, 4rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0;
  }

  .article-hero__summary {
    max-width: 640px;
    margin: 24px 0 0;
    color: var(--color-secondary);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .article-question {
    margin: 32px 0 0;
    border-left: 3px solid var(--color-tertiary);
    padding: 24px;
    background: var(--color-surface-muted);
  }

  .article-question h2,
  .article-question p {
    margin: 0;
  }

  .article-question h2 {
    color: var(--color-primary);
    font-size: 1.375rem;
    font-weight: 750;
    line-height: 1.28;
  }

  .article-question p {
    margin-top: 12px;
    color: var(--color-secondary);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .article-hero__content {
      padding-bottom: 32px;
    }

    .article-hero__title {
      line-height: 1.08;
    }

    .article-question {
      padding: 20px;
    }
  }
</style>
