{
  "name": "my-blog-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:blog": "pnpm --filter @my-blog/blog dev",
    "dev:admin": "pnpm --filter @my-blog/admin dev",
    "dev:api": "pnpm --filter @my-blog/api dev",
    "build": "pnpm -r build",
    "build:blog": "pnpm --filter @my-blog/blog build",
    "build:admin": "pnpm --filter @my-blog/admin build",
    "build:api": "pnpm --filter @my-blog/api build",
    "check": "pnpm -r --filter \"./packages/**\" build && pnpm -r check"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
