{
  "name": "my-blog-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:blog": "turbo run dev --filter=@my-blog/blog",
    "dev:admin": "turbo run dev --filter=@my-blog/admin",
    "dev:api": "turbo run dev --filter=@my-blog/api",
    "build": "turbo run build",
    "build:blog": "turbo run build --filter=@my-blog/blog",
    "build:admin": "turbo run build --filter=@my-blog/admin",
    "build:api": "turbo run build --filter=@my-blog/api",
    "check": "pnpm check:adr && turbo run check",
    "check:adr": "node scripts/validate-adr.mjs",
    "scan:boundaries": "node .codex/tools/contract-boundary-permissions/scripts/scan-boundaries.mjs",
    "refresh:generated": "node .codex/tools/contract-boundary-permissions/scripts/refresh-generated.mjs"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "typescript": "^5.9.3"
  }
}
