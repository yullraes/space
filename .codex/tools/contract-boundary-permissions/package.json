{
  "name": "contract-boundary-permission-bundle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Markdown contract-boundary based Codex permission automation.",
  "scripts": {
    "generate:permissions": "node src/generate-codex-permissions.ts",
    "generate:rules": "node src/generate-codex-rules.ts",
    "scan:boundaries": "node scripts/scan-boundaries.mjs",
    "refresh:generated": "node scripts/refresh-generated.mjs",
    "check:generated": "node scripts/refresh-generated.mjs --check",
    "validate:permissions": "node src/validate-codex-permissions.ts",
    "render:pre-commit-hook": "node scripts/render-pre-commit-hook.mjs",
    "hook:contract-boundary-pre-commit": "node hooks/pre-commit.mjs"
  },
  "engines": {
    "node": ">=22.6"
  }
}
